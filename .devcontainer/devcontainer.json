{
  "name": "cpp23-template",
  "image": "mcr.microsoft.com/devcontainers/cpp:1-ubuntu-24.04",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cmake-tools",
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "llvm-vs-code-extensions.vscode-clangd",
        "xaver.clang-format"
      ]
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y ninja-build pkg-config"
}
